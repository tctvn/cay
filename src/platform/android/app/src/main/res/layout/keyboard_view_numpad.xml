<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kbd_bg"
    android:padding="4dp">

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <TextView android:id="@+id/key_1" style="@style/KeyStyle" android:text="1" />
        <TextView android:id="@+id/key_2" style="@style/KeyStyle" android:text="2" />
        <TextView android:id="@+id/key_3" style="@style/KeyStyle" android:text="3" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <TextView android:id="@+id/key_4" style="@style/KeyStyle" android:text="4" />
        <TextView android:id="@+id/key_5" style="@style/KeyStyle" android:text="5" />
        <TextView android:id="@+id/key_6" style="@style/KeyStyle" android:text="6" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <TextView android:id="@+id/key_7" style="@style/KeyStyle" android:text="7" />
        <TextView android:id="@+id/key_8" style="@style/KeyStyle" android:text="8" />
        <TextView android:id="@+id/key_9" style="@style/KeyStyle" android:text="9" />
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <TextView android:id="@+id/key_abc" style="@style/SpecialKeyStyle" android:text="ABC" />
        <TextView android:id="@+id/key_0" style="@style/KeyStyle" android:text="0" />
        <TextView android:id="@+id/key_delete" style="@style/SpecialKeyStyle" android:text="⌫" />
    </LinearLayout>

</LinearLayout>
