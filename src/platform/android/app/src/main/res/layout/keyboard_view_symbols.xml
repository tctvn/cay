<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kbd_bg"
    android:padding="4dp">

    <!-- Row 1: Numbers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="3dp">
        <TextView android:id="@+id/key_1" style="@style/KeyStyle" android:text="1" />
        <TextView android:id="@+id/key_2" style="@style/KeyStyle" android:text="2" />
        <TextView android:id="@+id/key_3" style="@style/KeyStyle" android:text="3" />
        <TextView android:id="@+id/key_4" style="@style/KeyStyle" android:text="4" />
        <TextView android:id="@+id/key_5" style="@style/KeyStyle" android:text="5" />
        <TextView android:id="@+id/key_6" style="@style/KeyStyle" android:text="6" />
        <TextView android:id="@+id/key_7" style="@style/KeyStyle" android:text="7" />
        <TextView android:id="@+id/key_8" style="@style/KeyStyle" android:text="8" />
        <TextView android:id="@+id/key_9" style="@style/KeyStyle" android:text="9" />
        <TextView android:id="@+id/key_0" style="@style/KeyStyle" android:text="0" />
    </LinearLayout>

    <!-- Row 2: Symbols 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="3dp">
        <TextView android:id="@+id/key_minus" style="@style/KeyStyle" android:text="-" />
        <TextView android:id="@+id/key_slash" style="@style/KeyStyle" android:text="/" />
        <TextView android:id="@+id/key_colon" style="@style/KeyStyle" android:text=":" />
        <TextView android:id="@+id/key_semicolon" style="@style/KeyStyle" android:text=";" />
        <TextView android:id="@+id/key_lparen" style="@style/KeyStyle" android:text="(" />
        <TextView android:id="@+id/key_rparen" style="@style/KeyStyle" android:text=")" />
        <TextView android:id="@+id/key_dollar" style="@style/KeyStyle" android:text="$" />
        <TextView android:id="@+id/key_ampersand" style="@style/KeyStyle" android:text="&amp;" />
        <TextView android:id="@+id/key_at" style="@style/KeyStyle" android:text="\@" />
        <TextView android:id="@+id/key_doublequote" style="@style/KeyStyle" android:text="&quot;" />
    </LinearLayout>

    <!-- Row 3: Symbols 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="3dp">
        <TextView android:id="@+id/key_hash" style="@style/KeyStyle" android:text="#" android:layout_weight="1.5" />
        <TextView android:id="@+id/key_plus" style="@style/KeyStyle" android:text="+" />
        <TextView android:id="@+id/key_equal" style="@style/KeyStyle" android:text="=" />
        <TextView android:id="@+id/key_period" style="@style/KeyStyle" android:text="." />
        <TextView android:id="@+id/key_comma" style="@style/KeyStyle" android:text="," />
        <TextView android:id="@+id/key_question" style="@style/KeyStyle" android:text="?" />
        <TextView android:id="@+id/key_exclamation" style="@style/KeyStyle" android:text="!" />
        <TextView android:id="@+id/key_quote" style="@style/KeyStyle" android:text="\'" />
        <TextView android:id="@+id/key_delete" style="@style/SpecialKeyStyle" android:text="⌫" android:layout_weight="1.5" />
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <TextView android:id="@+id/key_abc" style="@style/SpecialKeyStyle" android:text="ABC" android:layout_weight="1.5" />
        <ImageView android:id="@+id/key_emoji" style="@style/SpecialKeyStyle" android:src="@drawable/ic_emoji" android:layout_weight="1" />
        <TextView android:id="@+id/key_space" style="@style/KeyStyle" android:text="Space" android:layout_weight="4" />
        <TextView android:id="@+id/key_enter" style="@style/SpecialKeyStyle" android:text="⏎" android:layout_weight="1.5" />
    </LinearLayout>

    <!-- Row 5 (Bottom Bar) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginTop="2dp"
        android:paddingBottom="4dp"
        android:paddingTop="4dp">
        <ImageView android:id="@+id/key_globe" android:layout_width="48dp" android:layout_height="48dp" android:padding="10dp" android:src="@drawable/ic_globe" android:background="@null" />
        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        <ImageView android:id="@+id/key_mic" android:layout_width="48dp" android:layout_height="48dp" android:padding="10dp" android:src="@drawable/ic_mic" android:background="@null" />
    </LinearLayout>

</LinearLayout>
